# Copy to .env and fill in. `run.sh` sources this file before running.
# --- Email (Gmail App Password recommended) ------------------------------- #
SMTP_USER=youraddress@gmail.com
SMTP_PASS=your_16_char_app_password      # Google account > Security > App passwords
ALERT_TO=youraddress@gmail.com            # comma-separated for multiple recipients
# Optional overrides (defaults shown):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465

# --- Telegram (optional alternative/addition) ----------------------------- #
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_CHAT_ID=123456789
